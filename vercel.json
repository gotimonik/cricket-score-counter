{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.cricket-score-counter.com"
        },
        {
          "type": "header",
          "key": "x-forwarded-proto",
          "value": "http"
        }
      ],
      "destination": "https://www.cricket-score-counter.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "cricket-score-counter.com"
        }
      ],
      "destination": "https://www.cricket-score-counter.com/$1",
      "permanent": true
    },
    {
      "source": "/join-game/",
      "destination": "/join-game",
      "permanent": true
    },
    {
      "source": "/privacy-policy/",
      "destination": "/privacy-policy",
      "permanent": true
    },
    {
      "source": "/create-game/",
      "destination": "/create-game",
      "permanent": true
    },
    {
      "source": "/disclaimer/",
      "destination": "/disclaimer",
      "permanent": true
    },
    {
      "source": "/v1",
      "destination": "/",
      "permanent": true
    },
    {
      "source": "/v1/(.*)",
      "destination": "/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000; includeSubDomains; preload"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
